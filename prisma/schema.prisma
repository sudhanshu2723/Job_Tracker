generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  applications Application[]

  sentInvites     Invitation[] @relation("SentInvites")
  receivedInvites Invitation[] @relation("ReceivedInvites")
  sentFriendReqs  Friendship[] @relation("SentFriendReqs")
  recvFriendReqs  Friendship[] @relation("RecvFriendReqs")

  @@map("users")
}

// Pending signup awaiting email OTP verification (one per email).
model SignupOtp {
  email        String   @id
  username     String
  passwordHash String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("signup_otps")
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  role        String
  location    String   @default("")
  country     String   @default("")
  source      String   @default("")
  dateApplied String   @default("")
  referral    Boolean  @default(false)
  referrer    String   @default("")
  status      String   @default("applied")
  ctc         String   @default("")
  link        String   @default("")
  followUp    String   @default("")
  notes       String   @default("")
  // Provenance for shared postings (null when the user created it themselves).
  sharedFrom  String?
  sourceAppId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, sourceAppId])
  @@index([userId])
  @@index([status])
  @@map("applications")
}

// One-time, date-ranged share request. The sender (fromUser) RECEIVES the
// recipient's (toUser) postings once the recipient accepts.
model Invitation {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  fromDate   String
  toDate     String
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())

  fromUser User @relation("SentInvites", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedInvites", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId])
  @@index([fromUserId])
  @@map("invitations")
}

// Mutual friendship with continuous two-way posting sync once accepted.
model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending | accepted
  createdAt   DateTime @default(now())

  requester User @relation("SentFriendReqs", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("RecvFriendReqs", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friendships")
}
